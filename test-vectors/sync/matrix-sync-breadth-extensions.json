    "request_descriptors": [
      {
        "id": "sync-query-extensions",
        "method": "GET",
        "path": "/_matrix/client/v3/sync",
        "query_params": {
          "filter": "filter-1",
          "full_state": true,
          "set_presence": "online",
          "since": "s1",
          "timeout": 0,
          "use_state_after": true
        },
        "requires_auth": true,
        "adopted_runtime_behavior": false,
        "response_parser": "sync_extensions"
      },
      {
        "id": "sync-lazy-load-filter",
        "method": "GET",
        "path": "/_matrix/client/v3/sync",
        "query_params": {
          "filter": {
            "room": {
              "state": {
                "lazy_load_members": true
              },
              "timeline": {
                "lazy_load_members": true
              }
            }
          },
          "timeout": 0
        },
        "requires_auth": true,
        "adopted_runtime_behavior": false,
        "response_parser": "sync_extensions"
      }
    ],
