{
  "name": "timeline-basic",
  "contract": "SPEC-010",
  "request": {
    "method": "GET",
    "path": "/_houra/client/rooms/!room:example.test/timeline",
    "access_token": "token-1",
    "query": {
      "from": "t1",
      "limit": "20"
    }
  },
  "expected": {
    "status": 200,
    "body_contains": {
      "events": [
        {
          "event_id": "$event:example.test",
          "room_id": "!room:example.test",
          "sender": "@alice:example.test",
          "origin_server_ts": 1710000000000,
          "type": "houra.room.message",
          "content": {
            "msgtype": "houra.text",
            "body": "hello"
          }
        }
      ],
      "start": "t1",
      "end": "t0"
    }
  }
}
