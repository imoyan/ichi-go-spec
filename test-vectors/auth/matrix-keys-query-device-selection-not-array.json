{
  "name": "matrix-keys-query-device-selection-not-array",
  "contract": "SPEC-069",
  "request": {
    "method": "POST",
    "path": "/_matrix/client/v3/keys/query",
    "access_token": "token-bob-device1",
    "body": {
      "device_keys": {
        "@alice:example.test": "DEVICE1"
      }
    }
  },
  "expected": {
    "status": 400,
    "error": {
      "errcode": "M_INVALID_PARAM",
      "error": "Device selections must be arrays."
    }
  }
}
