{
  "name": "matrix-registration-guest-upgrade-negative",
  "contract": "SPEC-033",
  "issue": "imoyan/houra-spec#430",
  "preconditions": {
    "guest_user_id": "@guest1:example.test",
    "guest_access_token": "token-guest",
    "guest_device_id": "GUEST1"
  },
  "request": {
    "method": "POST",
    "path": "/_matrix/client/v3/register",
    "body": {
      "username": "guest1",
      "password": "correct horse battery staple",
      "guest_access_token": "token-missing",
      "device_id": "UPGRADED"
    }
  },
  "cases": [
    {
      "name": "invalid_guest_upgrade_token",
      "request": {
        "method": "POST",
        "path": "/_matrix/client/v3/register",
        "body": {
          "username": "guest1",
          "password": "correct horse battery staple",
          "guest_access_token": "token-missing",
          "device_id": "UPGRADED"
        }
      },
      "expected": {
        "status": 403,
        "body_contains": {
          "errcode": "M_FORBIDDEN"
        },
        "guest_account_upgraded": false,
        "new_session_issued": false
      }
    },
    {
      "name": "mismatched_username",
      "request": {
        "method": "POST",
        "path": "/_matrix/client/v3/register",
        "body": {
          "username": "alice",
          "password": "correct horse battery staple",
          "guest_access_token": "token-guest",
          "device_id": "UPGRADED"
        }
      },
      "expected": {
        "status": 403,
        "body_contains": {
          "errcode": "M_FORBIDDEN"
        },
        "guest_account_upgraded": false,
        "new_session_issued": false
      }
    }
  ],
  "expected": {
    "versions_advertisement_widened": false,
    "excluded_breadth": [
      "room preview event stream",
      "guest-specific rate-limit policy",
      "guest-specific API allowlist breadth beyond representative createRoom rejection"
    ]
  }
}
