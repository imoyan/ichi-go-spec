{
  "name": "password-login-basic",
  "contract": "SPEC-004",
  "request": {
    "method": "POST",
    "path": "/_houra/client/login",
    "body": {
      "type": "houra.login.password",
      "identifier": {
        "type": "houra.id.user",
        "user": "alice"
      },
      "password": "correct horse battery staple",
      "device_id": "DEVICE1",
      "initial_device_display_name": "Alice phone"
    }
  },
  "expected": {
    "status": 200,
    "body_contains": {
      "user_id": "@alice:example.test",
      "access_token": "token-1",
      "device_id": "DEVICE1"
    }
  }
}
