{
  "name": "password-login-failure",
  "contract": "SPEC-004",
  "request": {
    "method": "POST",
    "path": "/_ichi-go/client/login",
    "body": {
      "type": "ichigo.login.password",
      "identifier": {
        "type": "ichigo.id.user",
        "user": "alice"
      },
      "password": "wrong password"
    }
  },
  "expected": {
    "status": 401,
    "body_contains": {
      "code": "CHAWAN_UNAUTHORIZED",
      "message": "Invalid login credentials."
    }
  }
