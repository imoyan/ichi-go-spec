{
  "name": "matrix-keys-upload-malformed-device-keys",
  "contract": "SPEC-051",
  "request": {
    "method": "POST",
    "path": "/_matrix/client/v3/keys/upload",
    "access_token": "token-alice-device1",
    "body": {
      "device_keys": {
        "user_id": "@mallory:example.test",
        "device_id": "DEVICE1",
        "algorithms": [
          "m.olm.v1.curve25519-aes-sha2"
        ],
        "keys": {
          "ed25519:DEVICE1": "ed25519-public-device1"
        },
        "signatures": {}
      }
    }
  },
  "expected": {
    "status": 400,
    "error": {
      "errcode": "M_INVALID_PARAM",
      "error": "Device keys do not match the authenticated device."
    }
  }
}
