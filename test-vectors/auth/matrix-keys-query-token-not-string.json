{
  "name": "matrix-keys-query-token-not-string",
  "contract": "SPEC-069",
  "request": {
    "method": "POST",
    "path": "/_matrix/client/v3/keys/query",
    "access_token": "token-bob-device1",
    "body": {
      "device_keys": {
        "@alice:example.test": []
      },
      "token": 10000
    }
  },
  "expected": {
    "status": 400,
    "error": {
      "errcode": "M_INVALID_PARAM",
      "error": "token must be a string."
    }
  }
}
