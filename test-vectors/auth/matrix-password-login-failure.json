{
  "name": "matrix-password-login-failure",
  "contract": "SPEC-032",
  "request": {
    "method": "POST",
    "path": "/_matrix/client/v3/login",
    "body": {
      "type": "m.login.password",
      "identifier": {
        "type": "m.id.user",
        "user": "alice"
      },
      "password": "wrong password"
    }
  },
  "expected": {
    "status": 403,
    "body_contains": {
      "errcode": "M_FORBIDDEN",
      "error": "Invalid login credentials."
    }
  }
}
