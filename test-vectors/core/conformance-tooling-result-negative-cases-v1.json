        "invalid_field": "houra_spec_commit",
        "reason": "report commit does not match the vector set used by the runner",
        "expected_result": "rejected"
      },
      {
        "id": "unknown-vector",
        "invalid_field": "results[0].vector_path",
        "reason": "vector path or vector name is absent from the consumed houra-spec checkout",
        "expected_result": "rejected"
      },
      {
        "id": "unknown-contract-id",
        "invalid_field": "results[0].contract",
        "reason": "contract id is not present in contracts/SPEC-*.md",
        "expected_result": "rejected"
      },
      {
        "id": "profile-mismatch",
        "invalid_field": "results[0].feature_profile",
        "reason": "feature profile does not match CONTRACT_MODULE_MAP.md for the result contract",
        "expected_result": "rejected"
      },
      {
        "id": "unredacted-failure-detail",
        "invalid_field": "results[0].failure_detail",
        "reason": "failure detail records a forbidden secret, credentialed URL, local path, key material, or plaintext payload category",
        "expected_result": "rejected"
      }
