          "case_id": "case-001",
          "report_type": "field_status",
          "status": "needs_follow_up",
          "gps_coordinates": "35.681236,139.767125"
        },
        "expected_status": "forbidden",
        "expected_error": "replay_raw_device_data"
      },
      {
        "id": "payload-drift-forbidden",
        "idempotency_key_ref": "sample_replay.idempotency_key",
        "repeat_after_case": "first-replay-accepted",
        "payload_patch": {
          "status": "completed"
        },
        "expected_status": "forbidden",
        "expected_error": "replay_payload_drift"
      },
      {
        "id": "server-owned-state-forbidden",
        "idempotency_key": "offline-replay-key-server-owned",
        "payload": {
          "case_id": "case-001",
          "report_type": "field_status",
          "status": "needs_follow_up",
          "accepted_state": "accepted"
        },
        "expected_status": "forbidden",
        "expected_error": "replay_server_owned_state"
      }
    ],
    "evidence_redaction": {
      "forbidden_raw_values_must_be_absent": [
        "35.681236,139.767125",
        "accelerometer-secret-sample",
        "/Users/alice/Library/Application Support/Houra/offline.db",
        "device-cache-secret",
