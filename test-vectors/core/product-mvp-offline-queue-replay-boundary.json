          "sensor_dump",
          "local_queue_path",
          "device_cache_key",
          "bearer_token",
          "debug_trace",
          "raw_device_payload"
        ]
      },
      {
        "id": "duplicate-replay-deduplicated",
        "idempotency_key_ref": "sample_replay.idempotency_key",
        "payload_ref": "sample_replay.payload",
        "repeat_after_case": "first-replay-accepted",
        "expected_status": "ok",
        "expected_replay_state": "deduplicated",
        "must_return_original_result": true,
        "must_not_create_second_operation": true
      },
      {
        "id": "missing-idempotency-key-forbidden",
        "payload_ref": "sample_replay.payload",
