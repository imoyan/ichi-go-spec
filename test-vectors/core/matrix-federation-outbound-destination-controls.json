        "candidate": "169.254.169.254:8448",
        "resolved_addresses": [
          "169.254.169.254"
        ],
        "expected_blocked": true,
        "expected_classification": "link_local",
        "federation_request_sent": false
      },
      {
        "id": "private-address-record",
        "stage": "address_records",
        "candidate": "private.example.test:8448",
        "resolved_addresses": [
          "10.0.0.7"
        ],
        "expected_blocked": true,
        "expected_classification": "private_use",
        "federation_request_sent": false
      },
      {
        "id": "redirect-to-private-well-known",
        "stage": "well_known_redirect",
        "candidate": "https://public.example.test/.well-known/matrix/server",
