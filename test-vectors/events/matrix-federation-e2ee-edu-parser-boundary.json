                  },
                  "signatures": {
                    "@alice:remote.example.test": {
                      "ed25519:remote-master-public": "signature-of-self-signing-by-master"
                    }
                  }
                }
              }
            },
            {
              "edu_type": "m.direct_to_device",
              "content": {
                "sender": "@alice:remote.example.test",
                "type": "m.room.encrypted",
                "message_id": "msg-fed-1",
                "messages": {
                  "@bob:example.test": {
                    "BOB1": {
                      "algorithm": "m.olm.v1.curve25519-aes-sha2",
                      "sender_key": "remote-curve25519-public",
                      "ciphertext": {
                        "bob-curve25519-bob1": {
                          "type": 0,
                          "body": "remote-olm-prekey-ciphertext"
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        },
