              "type": "m.room.member",
              "room_id": "!room:example.test",
              "sender": "@alice:remote.example.test",
              "state_key": "@alice:remote.example.test",
              "content": {
                "membership": "leave"
              }
            }
          }
        }
      },
      {
        "id": "send-leave",
        "method": "PUT",
        "path": "/_matrix/federation/v2/send_leave/!room:example.test/$leave:remote.example.test",
