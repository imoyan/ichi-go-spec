{
  "name": "matrix-messages-basic",
  "contract": "SPEC-036",
  "request": {
    "method": "GET",
    "path": "/_matrix/client/v3/rooms/!room:example.test/messages",
    "query": {
      "from": "t1",
      "dir": "b",
      "limit": 10
    },
    "headers": {
      "Authorization": "Bearer token-1"
    }
  },
  "expected": {
    "status": 200,
    "body_contains": {
      "chunk": [
        {
          "event_id": "$event1:example.test",
          "room_id": "!room:example.test",
          "sender": "@alice:example.test",
          "origin_server_ts": 1710000000000,
          "type": "m.room.message",
          "content": {
            "msgtype": "m.text",
            "body": "Hello Matrix"
          },
          "unsigned": {
            "transaction_id": "txn-1"
          }
        }
      ],
      "start": "t1",
      "end": "t0"
    }
  }
}
