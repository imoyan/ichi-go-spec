{
  "name": "matrix-cross-signing-missing-token",
  "contract": "SPEC-054",
  "event": {
    "matrix_spec_version": "v1.18",
    "matrix_spec_source": "https://spec.matrix.org/v1.18/client-server-api/#cross-signing",
    "checked_at": "2026-05-10T19:50:08+09:00",
    "required_contracts": [
      "SPEC-050",
      "SPEC-051",
      "SPEC-054"
    ],
    "steps": [
      {
        "id": "missing-token-device-signing-upload",
        "method": "POST",
        "path": "/_matrix/client/v3/keys/device_signing/upload",
        "body": {
          "self_signing_key": {
            "user_id": "@alice:example.test",
            "usage": [
              "self_signing"
            ],
            "keys": {
              "ed25519:self-signing-public": "self-signing-public"
            },
            "signatures": {
              "@alice:example.test": {
                "ed25519:not-the-master-key": "invalid-signature"
              }
            }
          }
        },
        "expected_status": 401,
        "expected_error": {
          "errcode": "M_MISSING_TOKEN",
          "error": "Missing access token."
        }
      },
      {
        "id": "missing-token-keys-query",
        "method": "POST",
        "path": "/_matrix/client/v3/keys/query",
        "body": {
          "device_keys": {
            "@alice:example.test": []
          }
        },
        "expected_status": 401,
        "expected_error": {
          "errcode": "M_MISSING_TOKEN",
          "error": "Missing access token."
        }
      },
      {
        "id": "missing-token-signatures-upload",
        "method": "POST",
        "path": "/_matrix/client/v3/keys/signatures/upload",
        "body": {
          "@alice:example.test": {
            "ALICE2": {
              "user_id": "@alice:example.test",
              "device_id": "ALICE2",
              "keys": {
                "ed25519:ALICE2": "ed25519-device-public"
              },
              "signatures": {
                "@alice:example.test": {
                  "ed25519:self-signing-public": "signature-of-device-by-self-signing"
                }
              }
            }
          }
        },
        "expected_status": 401,
        "expected_error": {
          "errcode": "M_MISSING_TOKEN",
          "error": "Missing access token."
        }
      }
    ],
    "auth_precedes_signature_validation": true
  },
  "expected": {
    "protected_key_operations_require_token": true,
    "semantic_errors_suppressed_until_authenticated": true,
    "versions_advertisement_widened": false
  }
}
