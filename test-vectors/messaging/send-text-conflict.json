{
  "name": "send-text-conflict",
  "contract": "SPEC-008",
  "given": {
    "previous_request": {
      "method": "POST",
      "path": "/_ichi-go/client/rooms/!room:example.test/messages",
      "access_token": "token-1",
      "body": {
        "client_transaction_id": "txn-1",
        "msgtype": "ichigo.text",
        "body": "hello"
      }
    },
    "previous_event_id": "$message:example.test"
  },
  "request": {
    "method": "POST",
    "path": "/_ichi-go/client/rooms/!room:example.test/messages",
    "access_token": "token-1",
    "body": {
      "client_transaction_id": "txn-1",
      "msgtype": "ichigo.text",
      "body": "changed"
    }
  },
  "expected": {
    "status": 409,
    "body_contains": {
      "code": "CHAWAN_CONFLICT",
      "message": "Conflicting message idempotency key."
    }
  }
}
