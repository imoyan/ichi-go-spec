{
  "name": "matrix-send-event-text-basic",
  "contract": "SPEC-036",
  "request": {
    "method": "PUT",
    "path": "/_matrix/client/v3/rooms/!room:example.test/send/m.room.message/txn-1",
    "body": {
      "msgtype": "m.text",
      "body": "Hello Matrix"
    },
    "access_token": "token-1"
  },
  "expected": {
    "status": 200,
    "body_contains": {
      "event_id": "$event1:example.test"
    }
  }
}
