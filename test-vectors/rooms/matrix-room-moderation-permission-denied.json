{
  "name": "matrix-room-moderation-permission-denied",
  "contract": "SPEC-049",
  "request": {
    "method": "POST",
    "path": "/_matrix/client/v3/rooms/!room:example.test/kick",
    "access_token": "token-bob",
    "body": {
      "user_id": "@carol:example.test",
      "reason": "No power"
    }
  },
  "expected": {
    "status": 403,
    "error": {
      "errcode": "M_FORBIDDEN",
      "error": "You do not have permission to kick from this room."
    }
  }
}
