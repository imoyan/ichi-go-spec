    "path": "/_matrix/client/v3/join/!room:example.test",
    "access_token": "token-guest",
    "body": {}
  },
  "expected": {
    "status": 403,
    "error": {
      "errcode": "M_FORBIDDEN"
    },
    "body_contains": {
