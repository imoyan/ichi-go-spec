{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://houra.dev/schemas/houra-ui-surface.schema.json",
  "title": "Houra UI surface",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "implementation_boundary",
    "theme_refs",
    "screens",
    "actions",
    "states",
    "text_keys",
    "acceptance_flows",
    "limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "implementation_boundary": {
      "type": "object",
      "required": [
        "platform_neutral",
        "server_impact",
        "canonical_behavior_source",
        "implementation_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "platform_neutral": {
          "type": "boolean",
          "const": true
        },
        "server_impact": {
          "type": "string",
          "const": "none"
        },
        "canonical_behavior_source": {
          "type": "string",
          "minLength": 1
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "theme_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/screen"
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/state"
      }
    },
    "text_keys": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/acceptanceFlow"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "screen": {
      "type": "object",
      "required": ["id", "session", "purpose", "regions", "fields", "actions"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "session": {
          "enum": ["unauthenticated", "authenticated", "any"]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "regions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["id", "label_key", "input", "required"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label_key": {
          "$ref": "#/$defs/textKey"
        },
        "input": {
          "enum": ["url", "localpart", "password", "text", "media-type"]
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "action": {
      "type": "object",
      "required": [
        "id",
        "label_key",
        "requires_auth",
        "api_contracts",
        "busy_state",
        "success_expectation",
        "error_expectation"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label_key": {
          "$ref": "#/$defs/textKey"
        },
        "requires_auth": {
          "type": "boolean"
        },
        "api_contracts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^SPEC-[0-9]{3}$"
          }
        },
        "busy_state": {
          "$ref": "#/$defs/id"
        },
        "disabled_when": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "success_expectation": {
          "type": "string",
          "minLength": 1
        },
        "error_expectation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["id", "kind", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": ["session", "async", "selection", "data", "error"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acceptanceFlow": {
      "type": "object",
      "required": ["id", "description", "steps"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/acceptanceStep"
          }
        }
      }
    },
    "acceptanceStep": {
      "type": "object",
      "required": ["id", "screen", "expectation"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "screen": {
          "$ref": "#/$defs/id"
        },
        "action": {
          "$ref": "#/$defs/id"
        },
        "expectation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "textKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"
    }
  }
}
